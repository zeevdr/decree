.nh
.TH "DECREE" "1" "Apr 2026" "OpenDecree" "OpenDecree CLI"

.SH NAME
decree - OpenDecree CLI


.SH SYNOPSIS
\fBdecree [flags]\fP


.SH DESCRIPTION
Command-line tool for managing schemas, tenants, and configuration values in OpenDecree.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for decree

.PP
\fB--insecure\fP[=true]
	skip TLS verification

.PP
\fB-o\fP, \fB--output\fP="table"
	output format: table, json, yaml

.PP
\fB--role\fP="superadmin"
	actor role (x-role header)

.PP
\fB--server\fP="localhost:9090"
	gRPC server address

.PP
\fB--subject\fP=""
	actor identity (x-subject header)

.PP
\fB--tenant-id\fP=""
	auth tenant ID (x-tenant-id header)

.PP
\fB--token\fP=""
	JWT bearer token


.SH SEE ALSO
\fBdecree-audit(1)\fP, \fBdecree-completion(1)\fP, \fBdecree-config(1)\fP, \fBdecree-diff(1)\fP, \fBdecree-docgen(1)\fP, \fBdecree-dump(1)\fP, \fBdecree-lock(1)\fP, \fBdecree-schema(1)\fP, \fBdecree-seed(1)\fP, \fBdecree-tenant(1)\fP, \fBdecree-validate(1)\fP, \fBdecree-version(1)\fP, \fBdecree-watch(1)\fP
