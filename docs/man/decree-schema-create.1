.nh
.TH "DECREE" "1" "Apr 2026" "OpenDecree" "OpenDecree CLI"

.SH NAME
decree-schema-create - Create a new schema from a YAML file


.SH SYNOPSIS
\fBdecree schema create [flags]\fP


.SH DESCRIPTION
Create a new schema from a YAML file


.SH OPTIONS
\fB-f\fP, \fB--file\fP=""
	YAML file with schema definition

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for create


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--insecure\fP[=true]
	skip TLS verification

.PP
\fB-o\fP, \fB--output\fP="table"
	output format: table, json, yaml

.PP
\fB--role\fP="superadmin"
	actor role (x-role header)

.PP
\fB--server\fP="localhost:9090"
	gRPC server address

.PP
\fB--subject\fP=""
	actor identity (x-subject header)

.PP
\fB--tenant-id\fP=""
	auth tenant ID (x-tenant-id header)

.PP
\fB--token\fP=""
	JWT bearer token


.SH SEE ALSO
\fBdecree-schema(1)\fP
