.nh
.TH "DECREE" "1" "Apr 2026" "OpenDecree" "OpenDecree CLI"

.SH NAME
decree-config-set-many - Set multiple config values atomically


.SH SYNOPSIS
\fBdecree config set-many  \&... [flags]\fP


.SH DESCRIPTION
Set multiple config values atomically


.SH OPTIONS
\fB--description\fP=""
	version description

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for set-many


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--insecure\fP[=true]
	skip TLS verification

.PP
\fB-o\fP, \fB--output\fP="table"
	output format: table, json, yaml

.PP
\fB--role\fP="superadmin"
	actor role (x-role header)

.PP
\fB--server\fP="localhost:9090"
	gRPC server address

.PP
\fB--subject\fP=""
	actor identity (x-subject header)

.PP
\fB--tenant-id\fP=""
	auth tenant ID (x-tenant-id header)

.PP
\fB--token\fP=""
	JWT bearer token


.SH SEE ALSO
\fBdecree-config(1)\fP
