.nh
.TH "DECREE" "1" "Apr 2026" "OpenDecree" "OpenDecree CLI"

.SH NAME
decree-audit - Query audit logs and usage statistics


.SH SYNOPSIS
\fBdecree audit [flags]\fP


.SH DESCRIPTION
Query the configuration change history and field read usage statistics. Useful for compliance auditing and identifying unused fields.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for audit


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--insecure\fP[=true]
	skip TLS verification

.PP
\fB-o\fP, \fB--output\fP="table"
	output format: table, json, yaml

.PP
\fB--role\fP="superadmin"
	actor role (x-role header)

.PP
\fB--server\fP="localhost:9090"
	gRPC server address

.PP
\fB--subject\fP=""
	actor identity (x-subject header)

.PP
\fB--tenant-id\fP=""
	auth tenant ID (x-tenant-id header)

.PP
\fB--token\fP=""
	JWT bearer token


.SH SEE ALSO
\fBdecree(1)\fP, \fBdecree-audit-query(1)\fP, \fBdecree-audit-unused(1)\fP, \fBdecree-audit-usage(1)\fP
